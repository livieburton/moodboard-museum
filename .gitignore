# Dependencies
node_modules/

# Vite build output — regenerated by `npm run build`
dist/

# Generated database — rebuilt from the CSV via `npm run build-db`
data/*.sqlite

# API response cache — lives outside OneDrive to avoid sync churn.
# Local path: C:\Users\livie\AppData\Local\moodboard-museum-cache\
# Regenerated on demand; never needs to be committed.
data/cache/

# The real Met CSV — it's ~300MB and downloaded separately, not committed.
# The small sample fixture in src/data/ IS committed (it's tiny and useful).
MetObjects.csv
*.csv.gz

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Environment variables — never commit secrets
.env
.env.local
.env.txt

# Logs
*.log
npm-debug.log*
